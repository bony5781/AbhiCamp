<% layout('../layout/boilerplate') %>

<div class="row">

  <h1 class="text-center mb-4">
    New Campground
  </h1>

  <div class="col-6 offset-3">

    <form
      action="/campgrounds"
      method="POST"
      novalidate
      class="validated-form"
      enctype="multipart/form-data"
    >

      <!-- TITLE -->
      <div class="mb-3">

        <label class="form-label" for="title">
          Title
        </label>

        <input
          class="form-control"
          type="text"
          name="campground[title]"
          id="title"
          required
        />

      </div>

      <!-- LOCATION -->
      <div class="mb-3">

        <label class="form-label">
          Location
        </label>

        <!-- SEARCH BAR -->
        <div id="geocoder"></div>

        <small class="text-muted">
          Search and select a location
        </small>

        <!-- HIDDEN INPUTS -->
        <input
          type="hidden"
          name="campground[location]"
          id="location"
        />

        <input
          type="hidden"
          name="campground[lat]"
          id="lat"
        />

        <input
          type="hidden"
          name="campground[lng]"
          id="lng"
        />

      </div>

      <!-- PRICE -->
      <div class="mb-3">

        <label class="form-label" for="price">
          Campground Price
        </label>

        <div class="input-group">

          <div class="input-group-prepend">
            <span class="input-group-text" id="price-label">
              ₹
            </span>
          </div>

          <input
            type="text"
            class="form-control"
            id="price"
            placeholder="100₹"
            aria-label="price"
            aria-describedby="price-label"
            name="campground[price]"
            required
          />

        </div>

      </div>

      <!-- DESCRIPTION -->
      <div class="mb-3">

        <label class="form-label" for="description">
          Description
        </label>

        <textarea
          class="form-control"
          name="campground[description]"
          id="description"
          required
        ></textarea>

      </div>

      <!-- IMAGE -->
      <div class="mb-3">

        <input
          class="form-control"
          name="image"
          type="file"
          id="images"
          multiple
        />

      </div>

      <!-- BUTTON -->
      <div class="mb-3">

        <button class="btn btn-success">
          Add Campground
        </button>

      </div>

    </form>

    <footer>

      <a href="/campgrounds">
        All Campgrounds
      </a>

    </footer>

  </div>

</div>

<!-- GEOCODER CSS -->
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.css"
/>

<!-- GEOCODER JS -->
<script src="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.js"></script>

<style>

  #geocoder {
    width: 100%;
    margin-bottom: 0.5rem;
  }

  .leaflet-control-geocoder {
    width: 100%;
    max-width: 100%;
    border: none;
    box-shadow: none;
    background: transparent;
  }

  .leaflet-control-geocoder-form {
    width: 100%;
  }

  .leaflet-control-geocoder-form input {
    width: 100%;
    padding: 12px 14px;
    border-radius: 6px;
    border: 1px solid #ced4da;
    font-size: 1rem;
  }

  .leaflet-control-geocoder-icon {
    display: none;
  }

</style>

<script>

  // HIDDEN MAP
  const hiddenMapDiv = document.createElement("div");

  hiddenMapDiv.style.height = "0px";
  hiddenMapDiv.style.width = "0px";

  document.body.appendChild(hiddenMapDiv);

  const hiddenMap = L.map(hiddenMapDiv);

  // CREATE GEOCODER
  const geocoder = L.Control.geocoder({
    defaultMarkGeocode: false,
    placeholder: "Search location..."
  });

  geocoder.addTo(hiddenMap);

  // INSERT SEARCH INPUT
  document
    .getElementById("geocoder")
    .appendChild(geocoder._container);

  // WHEN USER SELECTS LOCATION
  geocoder.on("markgeocode", function (e) {

    // LOCATION NAME
    document.getElementById("location").value =
      e.geocode.name;

    // LATITUDE
    document.getElementById("lat").value =
      e.geocode.center.lat;

    // LONGITUDE
    document.getElementById("lng").value =
      e.geocode.center.lng;

    // SHOW SELECTED TEXT
    document.querySelector(
      ".leaflet-control-geocoder-form input"
    ).value = e.geocode.name;

  });

</script>
