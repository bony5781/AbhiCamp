<% layout('../layout/boilerplate') %>

<div class="row">

  <h1 class="text-center mb-4">
    New Campground
  </h1>

  <div class="col-6 offset-3">

    <form
      action="/campgrounds"
      method="POST"
      novalidate
      class="validated-form"
      enctype="multipart/form-data"
    >

      <!-- TITLE -->
      <div class="mb-3">

        <label class="form-label" for="title">
          Title
        </label>

        <input
          class="form-control"
          type="text"
          name="campground[title]"
          id="title"
          required
        />

      </div>

      <!-- LOCATION -->
      <div class="mb-3">

        <label class="form-label">
          Location
        </label>

        <!-- SEARCH BAR -->
        <div id="geocoder"></div>

        <!-- HIDDEN INPUT -->
        <input
          type="hidden"
          name="campground[location]"
          id="location"
        />

      </div>

      <!-- PRICE -->
      <div class="mb-3">

        <label class="form-label" for="price">
          Campground Price
        </label>

        <div class="input-group">

          <div class="input-group-prepend">
            <span class="input-group-text" id="price-label">
              ₹
            </span>
          </div>

          <input
            type="text"
            class="form-control"
            id="price"
            placeholder="100₹"
            aria-label="price"
            aria-describedby="price-label"
            name="campground[price]"
            required
          />

        </div>

      </div>

      <!-- DESCRIPTION -->
      <div class="mb-3">

        <label class="form-label" for="description">
          Description
        </label>

        <textarea
          class="form-control"
          type="text"
          name="campground[description]"
          id="description"
          required
        ></textarea>

      </div>

      <!-- IMAGE -->
      <div class="mb-3">

        <input
          class="form-control"
          name="image"
          type="file"
          id="images"
          multiple
        />

      </div>

      <!-- BUTTON -->
      <div class="mb-3">

        <button class="btn btn-success">
          Add Campground
        </button>

      </div>

    </form>

    <footer>
      <a href="/campgrounds">
        All Campgrounds
      </a>
    </footer>

  </div>

</div>

<!-- OPENSTREETMAP GEOCODER CSS -->
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.css"
/>

<!-- OPENSTREETMAP GEOCODER JS -->
<script src="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.js"></script>

<script>

  // CREATE DUMMY MAP
  const dummyMap = L.map(document.createElement('div'));

  // CREATE GEOCODER
  const geocoder = L.Control.geocoder({
    defaultMarkGeocode: false,
    placeholder: "Search location..."
  });

  // ADD GEOCODER TO DUMMY MAP
  geocoder.addTo(dummyMap);

  // PUT SEARCH BAR INSIDE PAGE
  document
    .getElementById("geocoder")
    .appendChild(geocoder._container);

  // SAVE LOCATION
  geocoder.on("markgeocode", function (e) {

    const locationName = e.geocode.name;

    document.getElementById("location").value =
      locationName;

    // SHOW SELECTED TEXT
    document.querySelector(
      "#geocoder input"
    ).value = locationName;

  });

</script>
