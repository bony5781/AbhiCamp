<% layout('../layout/boilerplate') %>

<div class="row">

  <h1 class="text-center mb-4">
    New Campground
  </h1>

  <div class="col-6 offset-3">

    <form
      action="/campgrounds"
      method="POST"
      novalidate
      class="validated-form"
      enctype="multipart/form-data"
    >

      <!-- TITLE -->
      <div class="mb-3">

        <label class="form-label" for="title">
          Title
        </label>

        <input
          class="form-control"
          type="text"
          name="campground[title]"
          id="title"
          required
        />

      </div>

      <!-- LOCATION -->
      <div class="mb-3">

        <label class="form-label">
          Location
        </label>

        <!-- MAPBOX SEARCH BAR -->
        <div id="geocoder"></div>

        <!-- HIDDEN INPUT -->
        <input
          type="hidden"
          name="campground[location]"
          id="location"
          required
        />

      </div>

      <!-- PRICE -->
      <div class="mb-3">

        <label class="form-label" for="price">
          Campground Price
        </label>

        <div class="input-group">

          <div class="input-group-prepend">
            <span class="input-group-text" id="price-label">
              ₹
            </span>
          </div>

          <input
            type="text"
            class="form-control"
            id="price"
            placeholder="100₹"
            aria-label="price"
            aria-describedby="price-label"
            name="campground[price]"
            required
          />

        </div>

      </div>

      <!-- DESCRIPTION -->
      <div class="mb-3">

        <label class="form-label" for="description">
          Description
        </label>

        <textarea
          class="form-control"
          type="text"
          name="campground[description]"
          id="description"
          required
        ></textarea>

      </div>

      <!-- IMAGE -->
      <div class="mb-3">

        <input
          class="form-control"
          name="image"
          type="file"
          id="images"
          multiple
        />

      </div>

      <!-- BUTTON -->
      <div class="mb-3">

        <button class="btn btn-success">
          Add Campground
        </button>

      </div>

    </form>

    <footer>
      <a href="/campgrounds">
        All Campgrounds
      </a>
    </footer>

  </div>

</div>

<!-- OPENSTREETMAP GEOCODER -->

<script>

  const geocoder = L.Control.geocoder({
    defaultMarkGeocode: false
  });

  geocoder.addTo("#geocoder");

  geocoder.on("markgeocode", function(e) {

    const locationName = e.geocode.name;

    document.getElementById("location").value =
      locationName;

  });

</script>
